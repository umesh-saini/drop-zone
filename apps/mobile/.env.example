# Server connection (EXPO_PUBLIC_ vars are exposed to the app)
# Use your machine's LAN IP so a physical phone can reach the server,
# e.g. https://drop.devswitch.in — localhost won't work from a real device.
EXPO_PUBLIC_SERVER_URL=https://drop.devswitch.in
EXPO_PUBLIC_WS_URL=https://drop.devswitch.in
