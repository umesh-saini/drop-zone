# Server connection (EXPO_PUBLIC_ vars are exposed to the app)
# Use your machine's LAN IP so a physical phone can reach the server,
# e.g. http://192.168.29.225:3001 — localhost won't work from a real device.
EXPO_PUBLIC_SERVER_URL=http://192.168.29.225:3001
EXPO_PUBLIC_WS_URL=http://192.168.29.225:3001
