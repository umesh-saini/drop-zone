{
  "name": "desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.ts",
  "homepage": "./",
  "description": "DropZone is a fast, secure, and cross-platform application for file sharing, remote terminal access, and seamless device pairing over local and remote networks.",
  "author": {
    "name": "umesh-saini",
    "email": "umeshsaini8085@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/umesh-saini/DropZone.git"
  },
  "scripts": {
    "vite:dev": "vite --port 1420",
    "dev": "vite --port 1420",
    "electron:dev": "electron electron/main.ts --no-sandbox --dev",
    "build": "vite build",
    "electron:build": "vite build && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@dropzone/crypto": "workspace:^",
    "@dropzone/shared": "workspace:^",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tailwindcss/vite": "^4.3.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "adm-zip": "^0.5.17",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.9",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.21.0",
    "node-pty": "^1.1.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^24.13.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  },
  "build": {
    "appId": "com.dropzone.app",
    "productName": "DropZone",
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "icon": "build/icon.png",
      "category": "Utility"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png"
    },
    "mac": {
      "target": "default",
      "icon": "build/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "extendInfo": {
        "NSDocumentsFolderUsageDescription": "DropZone needs access to the Documents folder to save and load files.",
        "NSDownloadsFolderUsageDescription": "DropZone needs access to the Downloads folder to save received files.",
        "NSDesktopFolderUsageDescription": "DropZone needs access to the Desktop folder to save and load files.",
        "NSFullDiskAccessUsageDescription": "DropZone needs full disk access to share and manage files across your system."
      }
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "umesh-saini",
        "repo": "DropZone"
      }
    ]
  }
}